FROM golang:1.26-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /inventory ./cmd/inventory

FROM alpine:3.21
RUN apk add --no-cache ca-certificates
COPY --from=builder /inventory /inventory
RUN mkdir -p /data
EXPOSE 8084
ENTRYPOINT ["/inventory"]
